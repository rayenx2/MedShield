# Frontend (Vite)
# Keep empty to use relative paths (recommended for Vercel rewrites).
VITE_API_BASE_URL=
# Set to true to force mock auth mode in development.
VITE_ENABLE_MOCK_AUTH=false

# Backend (Node/Express)
DATABASE_URL=postgresql://username:password@hostname:5432/database
SESSION_SECRET=replace-with-a-long-random-secret
API_PORT=3001
API_HOST=0.0.0.0
# Comma-separated list of allowed browser origins for CORS.
ALLOWED_ORIGINS=http://localhost:5173
NODE_ENV=development

# Appwrite Storage (optional — leave all 3 blank to use local-disk storage
# at server/storage/ instead, with no functionality lost for local dev/demo)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_api_key
APPWRITE_BUCKET_ID=medshield-documents

# AI — Groq (https://console.groq.com/keys), used for document summarization
# (optional — leave blank and the AI Summary feature returns "not configured")
GROQ_API_KEY=your_groq_api_key